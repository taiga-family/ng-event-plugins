{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "ng-event-plugins",
    "projectType": "library",
    "sourceRoot": "libs/ng-event-plugins/src",
    "targets": {
        "build": {
            "executor": "@angular/build:ng-packagr",
            "options": {
                "project": "projects/{projectName}/ng-package.json",
                "tsConfig": "tsconfig.json"
            },
            "outputs": ["{workspaceRoot}/dist/{projectName}"]
        },
        "publish": {
            "dependsOn": [
                {
                    "dependencies": false,
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "nx:run-commands",
            "options": {
                "commands": ["cp ./LICENSE ./README.md ./dist/{projectName}", "npm publish ./dist/{projectName} --ignore-scripts"],
                "parallel": false
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "options": {
                "jestConfig": "jest.config.ts",
                "passWithNoTests": true
            },
            "outputs": ["{workspaceRoot}/coverage/{projectName}"]
        }
    }
}
